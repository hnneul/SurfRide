    "checkJs": false,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "strict": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
